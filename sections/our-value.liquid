{% comment %}
  Section: Our Value (50/50 Split Layout)
  Description: A premium boxed section with a text/icon grid on the left and a full uncropped image on the right.
{% endcomment %}

<div id="hh-values-{{ section.id }}" class="hh-section-outer">
  <div class="hh-values-container">
    
    <!-- Left Content Column -->
    <div class="hh-values-left">
      <div class="hh-values-content">
        
        <div class="hh-animate-element">
          {% if section.settings.kicker != blank %}
            <h6 class="hh-v-kicker">{{ section.settings.kicker }}</h6>
          {% endif %}
          
          {% if section.settings.heading != blank %}
            <h2 class="hh-v-heading">{{ section.settings.heading }}</h2>
          {% endif %}
          
          {% if section.settings.text != blank %}
            <div class="hh-v-desc">{{ section.settings.text }}</div>
          {% endif %}
          
          <div class="hh-v-divider"></div>
        </div>
        
        <!-- Icon Grid -->
        <div class="hh-v-grid">
          {% for block in section.blocks %}
            <div class="hh-v-item hh-animate-element delay-{{ forloop.index }}" {{ block.shopify_attributes }}>
              <div class="hh-v-icon">
                {% if block.settings.icon_img != blank %}
                  <img src="{{ block.settings.icon_img | image_url: width: 80 }}" alt="{{ block.settings.title | escape }}" loading="lazy" width="36" height="36">
                {% else %}
                  {{ block.settings.icon_svg }}
                {% endif %}
              </div>
              <h4 class="hh-v-item-title">{{ block.settings.title }}</h4>
              <p class="hh-v-item-desc">{{ block.settings.description }}</p>
            </div>
          {% endfor %}
        </div>
        
      </div>
    </div>
    
    <!-- Right Image Column (No Animations, No Cropping) -->
    <div class="hh-values-right">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | image_url: width: 1500 }}" 
             alt="{{ section.settings.heading | escape }}" 
             loading="lazy" 
             class="hh-v-image"
             width="{{ section.settings.image.width }}"
             height="{{ section.settings.image.height }}">
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hh-v-image hh-placeholder' }}
      {% endif %}
    </div>

  </div>
</div>

<style>
  #hh-values-{{ section.id }} {
    --hh-v-bg: {{ section.settings.bg_color }};
    --hh-v-right-bg: {{ section.settings.right_bg_color }};
    --hh-v-accent: {{ section.settings.brand_color }};
    --hh-v-heading: {{ section.settings.heading_color }};
    --hh-v-text: {{ section.settings.text_color }};
  }

  #hh-values-{{ section.id }}.hh-section-outer {
    width: 100%;
    padding: {{ section.settings.padding_top }}px 20px {{ section.settings.padding_bottom }}px 20px;
    background-color: {{ section.settings.outer_bg_color }};
    box-sizing: border-box;
  }

  #hh-values-{{ section.id }} .hh-values-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    border-radius: {{ section.settings.border_radius }}px;
    overflow: hidden;
    display: flex;
    flex-wrap: wrap;
    background-color: var(--hh-v-bg);
    box-shadow: 0 15px 40px rgba(0,0,0,0.04);
  }

  #hh-values-{{ section.id }} .hh-values-left {
    width: 50%;
    background-color: var(--hh-v-bg);
    padding: 4em;
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
  }


  /* Right Column — stretches fully to fill container height */
  #hh-values-{{ section.id }} .hh-values-right {
    width: 50%;
    background-color: var(--hh-v-right-bg);
    display: flex;
    align-items: stretch;
    justify-content: center;
    box-sizing: border-box;
    overflow: hidden;
  }

  /* Image fills the full column height with no gaps */
  #hh-values-{{ section.id }} .hh-v-image {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    object-position: center;
  }

  #hh-values-{{ section.id }} .hh-placeholder {
    background: #e9e9e9;
    fill: #a3a3a3;
    width: 100%;
    height: 100%;
  }

  #hh-values-{{ section.id }} .hh-v-kicker {
    color: var(--hh-v-accent);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    margin: 0 0 15px 0;
    font-family: sans-serif;
  }

  #hh-values-{{ section.id }} .hh-v-heading {
    color: var(--hh-v-heading);
    font-family: "Playfair Display", Georgia, serif;
    font-size: 46px;
    line-height: 1.15;
    font-weight: 500;
    margin: 0 0 20px 0;
  }

  #hh-values-{{ section.id }} .hh-v-desc {
    color: var(--hh-v-text);
    font-size: 16px;
    line-height: 1.7;
    margin: 0 0 40px 0;
  }

  #hh-values-{{ section.id }} .hh-v-desc p {
    margin: 0;
  }

  #hh-values-{{ section.id }} .hh-v-divider {
    width: 100%;
    height: 1px;
    background-color: var(--hh-v-accent);
    margin-bottom: 50px;
    opacity: 0.6;
  }

  #hh-values-{{ section.id }} .hh-v-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 40px 30px;
  }

  #hh-values-{{ section.id }} .hh-v-item {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  #hh-values-{{ section.id }} .hh-v-icon {
    margin-bottom: 15px;
    color: var(--hh-v-accent);
  }

  #hh-values-{{ section.id }} .hh-v-icon svg {
    width: 36px;
    height: 36px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.5;
  }

  #hh-values-{{ section.id }} .hh-v-icon img {
    width: 36px;
    height: auto;
    object-fit: contain;
  }

  #hh-values-{{ section.id }} .hh-v-item-title {
    color: var(--hh-v-heading);
    font-family: "Playfair Display", Georgia, serif;
    font-size: 20px;
    font-weight: 600;
    margin: 0 0 8px 0;
  }

  #hh-values-{{ section.id }} .hh-v-item-desc {
    color: var(--hh-v-text);
    font-size: 14px;
    line-height: 1.6;
    margin: 0;
  }

  #hh-values-{{ section.id }} .hh-animate-element {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  #hh-values-{{ section.id }} .hh-animate-element.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  #hh-values-{{ section.id }} .delay-1 { transition-delay: 0.1s; }
  #hh-values-{{ section.id }} .delay-2 { transition-delay: 0.2s; }
  #hh-values-{{ section.id }} .delay-3 { transition-delay: 0.3s; }
  #hh-values-{{ section.id }} .delay-4 { transition-delay: 0.4s; }

  /* Tablet — stack vertically, image goes below */
  @media (max-width: 1024px) {
    #hh-values-{{ section.id }} .hh-values-container {
      flex-direction: column;
    }

    #hh-values-{{ section.id }} .hh-values-left {
      width: 100%;
      padding: 80px 40px;
    }

    #hh-values-{{ section.id }} .hh-values-content {
      max-width: 700px;
    }

    /* Image column takes its own height from the image itself */
    #hh-values-{{ section.id }} .hh-values-right {
      width: 100%;
      min-height: 500px;
    }

    #hh-values-{{ section.id }} .hh-v-image {
      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  @media (max-width: 767px) {
    #hh-values-{{ section.id }}.hh-section-outer {
      padding: 40px 15px;
    }

    #hh-values-{{ section.id }} .hh-values-container {
      border-radius: 16px;
    }

    #hh-values-{{ section.id }} .hh-values-left {
      padding: 50px 20px;
    }

    #hh-values-{{ section.id }} .hh-v-heading {
      font-size: 32px;
      margin-bottom: 15px;
    }

    #hh-values-{{ section.id }} .hh-v-desc {
      font-size: 15px;
      margin-bottom: 30px;
    }

    #hh-values-{{ section.id }} .hh-v-divider {
      margin-bottom: 30px;
    }

    #hh-values-{{ section.id }} .hh-v-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    #hh-values-{{ section.id }} .hh-values-right {
      min-height: 350px;
    }
  }
</style>

<script>
  (function() {
    function initHhValues() {
      const section = document.getElementById('hh-values-{{ section.id }}');
      if (!section) return;

      const animatedElements = section.querySelectorAll('.hh-animate-element');

      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -10% 0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver((entries, obs) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            obs.unobserve(entry.target);
          }
        });
      }, observerOptions);

      animatedElements.forEach(el => observer.observe(el));
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initHhValues);
    } else {
      initHhValues();
    }

    document.addEventListener('shopify:section:load', function(e) {
      if (e.target.querySelector('#hh-values-{{ section.id }}')) {
        initHhValues();
      }
    });
  })();
</script>

