<div id="ph-section-{{ section.id }}" class="ph-section-wrapper">
  <div class="ph-container">
    
    <!-- SECTION HEADER (Heading & Description like the image) -->
    <div class="ph-section-header ph-animate-up">
      {% if section.settings.heading != blank %}
        <h2 class="ph-section-title">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.description != blank %}
        <div class="ph-section-desc">{{ section.settings.description }}</div>
      {% endif %}
    </div>

    <!-- PRODUCT CARDS GRID -->
    <div class="ph-products-area ph-animate-up delay-1">
      <div class="ph-slider-container" id="ph-slider-{{ section.id }}">
        <div class="ph-products-grid">
          {% assign collection = collections[section.settings.collection] %}
          {% assign product_limit = section.settings.product_limit %}
          
          {% if collection != blank and collection.products_count > 0 %}
            {% for product in collection.products limit: product_limit %}
              <div class="ph-product-card">
                <a href="{{ product.url }}" class="ph-product-img-link">
                  <div class="ph-product-img-wrapper">
                    <img src="{{ product.featured_image | image_url: width: 600 }}" 
                         alt="{{ product.title | escape }}"
                         loading="lazy"
                         width="{{ product.featured_image.width }}"
                         height="{{ product.featured_image.height }}">
                  </div>
                </a>
                <div class="ph-product-info">
                  <h4 class="ph-product-title">
                    <a href="{{ product.url }}">{{ product.title }}</a>
                  </h4>
                  <div class="ph-product-stars">
                    {% for i in (1..5) %}
                      <svg viewBox="0 0 24 24" fill="currentColor" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {% endfor %}
                  </div>
                  <div class="ph-product-price">{{ product.price | money }}</div>
                  <form method="post" action="/cart/add" class="ph-add-to-cart-form">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <button type="submit" class="ph-add-btn" {% if product.available == false %}disabled{% endif %}>
                      {% if product.available %}Add to cart{% else %}Sold Out{% endif %}
                    </button>
                  </form>
                </div>
              </div>
            {% endfor %}
          {% else %}
            <!-- Placeholder if no collection is selected -->
            {% for i in (1..4) %}
              <div class="ph-product-card">
                <a href="#" class="ph-product-img-link">
                  <div class="ph-product-img-wrapper">
                    {{ 'product-' | append: i | placeholder_svg_tag }}
                  </div>
                </a>
                <div class="ph-product-info">
                  <h4 class="ph-product-title"><a href="#">Heel Heroes Intensive Repair</a></h4>
                  <div class="ph-product-stars">
                    {% for j in (1..5) %}
                      <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    {% endfor %}
                  </div>
                  <div class="ph-product-price">$22.99</div>
                  <button class="ph-add-btn" disabled>Add to cart</button>
                </div>
              </div>
            {% endfor %}
          {% endif %}
        </div>
      </div>
    </div>
    
  </div>
</div>

<style>
  #ph-section-{{ section.id }} {
    --ph-accent-color: {{ section.settings.accent_color }};
    --ph-text-dark: #8C827A;
    --ph-text-light: #999999;
    --ph-card-bg: #FFFFFF;
    --ph-transition: 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .ph-section-wrapper {
    width: 100%;
    padding: 80px 20px;
    background: {{ section.settings.section_bg }};
    overflow: hidden;
    box-sizing: border-box;
  }

  .ph-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
  }

  /* ─── HEADER SECTION (Matching your image) ──────────────────────── */
  .ph-section-header {
    text-align: center;
    max-width: 800px;
    margin: 0 auto 60px auto;
  }

  .ph-section-title {
    color: var(--ph-text-dark);
    font-size: 36px;
    font-weight: 600;
    margin: 0 0 20px 0;
  }

  .ph-section-desc {
    color: var(--ph-text-light);
    font-size: 16px;
    line-height: 1.6;
  }
  .ph-section-desc p {
    margin: 0;
  }

  /* ─── PRODUCTS GRID ─────────────────────────────────────── */
  .ph-products-area {
    position: relative;
    width: 100%;
  }

  .ph-slider-container {
    width: 100%;
    overflow: hidden;
  }

  .ph-products-grid {
    display: grid;
    /* This will keep products on the left if there's only 1, or fill the grid if there are 4 */
    grid-template-columns: repeat(4, 1fr); 
    gap: 30px;
    width: 100%;
  }

  .ph-product-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--ph-card-bg);
    transition: transform var(--ph-transition);
  }

  .ph-product-img-link {
    width: 100%;
    display: block;
    border-radius: 12px;
    overflow: hidden;
    background: #f8f8f8;
    aspect-ratio: 1 / 1;
    margin-bottom: 20px;
  }

  .ph-product-img-wrapper {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .ph-product-img-wrapper img,
  .ph-product-img-wrapper svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .ph-product-card:hover .ph-product-img-wrapper img { transform: scale(1.05); }

  .ph-product-info {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ph-product-title {
    margin: 0 0 10px 0;
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    line-height: 1.4;
  }

  .ph-product-title a {
    color: var(--ph-accent-color);
    text-decoration: none;
    transition: opacity 0.3s;
  }

  .ph-product-title a:hover { opacity: 0.7; }

  .ph-product-stars {
    display: flex;
    gap: 2px;
    margin-bottom: 12px;
  }

  .ph-product-stars svg {
    width: 16px;
    height: 16px;
    color: #54463F;
  }

  .ph-product-price {
    color: var(--ph-accent-color);
    font-size: 16px;
    font-weight: 500;
    margin-bottom: 15px;
  }

  .ph-add-to-cart-form {
    width: 100%;
    display: flex;
    justify-content: center;
  }

  .ph-add-btn {
    background: var(--ph-accent-color);
    color: white;
    border: none;
    padding: 10px 24px;
    border-radius: 6px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--ph-transition);
  }

  .ph-add-btn:hover:not([disabled]) {
    background: #d85141; /* Slightly lighter shade for hover */
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(219, 74, 53, 0.3);
  }

  .ph-add-btn[disabled] {
    opacity: 0.5;
    cursor: not-allowed;
  }

  /* ─── ANIMATIONS ──────────────────────────────────────────────────────── */
  .ph-animate-up {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease, transform 0.8s ease;
  }

  .ph-animate-up.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .delay-1 { transition-delay: 0.2s; }

  /* ─── RESPONSIVE ──────────────────────────────────────────────────────── */
  @media (max-width: 991px) {
    .ph-products-grid { grid-template-columns: repeat(3, 1fr); gap: 20px; }
    .ph-section-title { font-size: 30px; }
  }

  @media (max-width: 767px) {
    .ph-section-wrapper { padding: 50px 15px; }
    .ph-section-title { font-size: 26px; }
    .ph-section-desc { font-size: 14px; }
    
    .ph-products-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 15px;
    }
  }
  
  @media (max-width: 480px) {
    .ph-products-grid {
      grid-template-columns: repeat(1, 1fr);
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('ph-section-{{ section.id }}');
    if (!section) return;

    // ─── DESKTOP DRAG-TO-SCROLL ────────────────────────────────────────────
    const slider = section.querySelector('.ph-slider-container');
    let isDown = false, startX, scrollLeft;

    if (slider) {
      slider.addEventListener('mousedown', (e) => {
        isDown = true;
        slider.style.cursor = 'grabbing';
        startX = e.pageX - slider.offsetLeft;
        scrollLeft = slider.scrollLeft;
      });
      slider.addEventListener('mouseleave', () => { isDown = false; slider.style.cursor = 'grab'; });
      slider.addEventListener('mouseup',    () => { isDown = false; slider.style.cursor = 'grab'; });
      slider.addEventListener('mousemove', (e) => {
        if (!isDown) return;
        e.preventDefault();
        slider.scrollLeft = scrollLeft - (e.pageX - slider.offsetLeft - startX) * 2;
      });
    }

    // ─── ENTRANCE ANIMATIONS ──────────────────────────────────────────────
    const observer = new IntersectionObserver((entries, obs) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          obs.unobserve(entry.target);
        }
      });
    }, { rootMargin: '0px 0px -10% 0px', threshold: 0.1 });

    section.querySelectorAll('.ph-animate-up').forEach(el => observer.observe(el));


    // ─── AJAX ADD TO CART & OPEN DRAWER ──────────────────────────────────
    const addToCartForms = section.querySelectorAll('.ph-add-to-cart-form');
    
    addToCartForms.forEach(form => {
      form.addEventListener('submit', async (e) => {
        e.preventDefault(); // পেজ রিলোড বন্ধ করবে
        
        const submitBtn = form.querySelector('.ph-add-btn');
        if (!submitBtn || submitBtn.disabled) return;
        
        const originalText = submitBtn.textContent;
        submitBtn.textContent = 'Adding...'; // কার্টে অ্যাড হওয়ার সময় বাটন টেক্সট পরিবর্তন হবে
        submitBtn.disabled = true;

        try {
          const formData = new FormData(form);
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            body: formData
          });

          if (response.ok) {
            // সফলভাবে অ্যাড হলে হেডার এর কার্ট আইকনে ক্লিক ইভেন্ট ট্রিগার করবে
            const cartDrawerBtn = document.querySelector('.hhN__cart-btn');
            if (cartDrawerBtn) {
              cartDrawerBtn.click();
            } else {
              window.location.href = '/cart'; // কার্ট বাটন খুঁজে না পেলে কার্ট পেজে নিয়ে যাবে
            }
          } else {
            console.error('Failed to add to cart');
          }
        } catch (error) {
          console.error('Error:', error);
        } finally {
          submitBtn.textContent = originalText;
          submitBtn.disabled = false;
        }
      });
    });

  });
</script>

{% schema %}
{
  "name": "Featured Product Cards",
  "settings": [
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 1800,
      "step": 50,
      "unit": "px",
      "label": "Maximum Width",
      "default": 1300
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Section Texts"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Never Run Out of Healthy Heels"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Consistency is key to lasting results. Subscribe and receive Heel Heroes delivered every 3 months—so your feet stay smooth, soft, and cared for year-round.</p>"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "range",
      "id": "product_limit",
      "min": 1,
      "max": 12,
      "step": 1,
      "label": "Maximum Products to Show",
      "default": 4
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color (Buttons, Price, Titles)",
      "default": "#d84531"
    }
  ],
  "presets": [
    {
      "name": "Featured Product Cards",
      "category": "Collection"
    }
  ]
}
{% endschema %}
