<div id="HeelHeroes-{{ section.id }}" class="hh-section">
  <div class="hh-container">
    
    <!-- Floating Navbar -->
    <header class="hh-navbar" id="Navbar-{{ section.id }}">
      <div class="hh-navbar-inner">
        <!-- Mobile Menu Toggle -->
        <button class="hh-mobile-toggle" aria-label="Menu" id="MobileToggle-{{ section.id }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M3 12h18M3 6h18M3 18h18"/></svg>
        </button>

        <!-- Left Navigation -->
        <nav class="hh-nav-left" id="NavMenu-{{ section.id }}">
          <button class="hh-mobile-close" aria-label="Close" id="MobileClose-{{ section.id }}">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
          </button>
          {% if section.settings.menu %}
            {% for link in linklists[section.settings.menu].links %}
              <a href="{{ link.url }}" class="hh-nav-link">{{ link.title }}</a>
            {% endfor %}
          {% else %}
            <a href="#" class="hh-nav-link">Home</a>
            <a href="#" class="hh-nav-link">About</a>
            <a href="#" class="hh-nav-link">Shop</a>
            <a href="#" class="hh-nav-link">Contact</a>
          {% endif %}
        </nav>

        <!-- Logo -->
        <a href="{{ routes.root_url }}" class="hh-logo">
          {% if section.settings.logo %}
            <img src="{{ section.settings.logo | image_url: width: 400 }}" alt="{{ shop.name }}" width="{{ section.settings.logo_width }}" height="auto" loading="eager">
          {% else %}
            <span class="hh-logo-text">{{ shop.name }}</span>
          {% endif %}
        </a>

        <!-- Right Icons -->
        <div class="hh-nav-right">
          <a href="{{ routes.cart_url }}" class="hh-icon-btn hh-cart-btn" aria-label="Cart">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><path d="M3 6h18M16 10a4 4 0 01-8 0"/></svg>
            {% if cart.item_count > 0 %}
              <span class="hh-cart-count">{{ cart.item_count }}</span>
            {% else %}
              <span class="hh-cart-count">0</span>
            {% endif %}
          </a>
          <a href="{{ routes.account_url }}" class="hh-icon-btn hh-login-btn">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2M12 11a4 4 0 100-8 4 4 0 000 8z"/></svg>
            <span>Login</span>
          </a>
        </div>
      </div>
    </header>

    <!-- Hero Slider -->
    <div class="hh-hero-wrapper">
      <div class="hh-slider" id="Slider-{{ section.id }}" data-speed="{{ section.settings.autoplay_speed | times: 1000 }}">
        {% assign slide_blocks = section.blocks | where: 'type', 'slide' %}
        {% for block in slide_blocks %}
          <div class="hh-slide {% if forloop.first %}is-active{% endif %}" {{ block.shopify_attributes }}>
            <div class="hh-slide-bg">
              {% if block.settings.image %}
                <img src="{{ block.settings.image | image_url: width: 2000 }}" alt="{{ block.settings.heading | escape }}" loading="{% if forloop.first %}eager{% else %}lazy{% endif %}" width="2000" height="1000">
              {% else %}
                {{ 'lifestyle-2' | placeholder_svg_tag: 'hh-placeholder' }}
              {% endif %}
              <div class="hh-overlay" style="opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};"></div>
            </div>
            
            <div class="hh-slide-content-wrap">
              <div class="hh-slide-content">
                {% if block.settings.subtitle != blank %}
                  <p class="hh-subtitle">{{ block.settings.subtitle }}</p>
                {% endif %}
                {% if block.settings.heading != blank %}
                  <h1 class="hh-heading">{{ block.settings.heading }}</h1>
                {% endif %}
                {% if block.settings.text != blank %}
                  <p class="hh-text">{{ block.settings.text }}</p>
                {% endif %}
                {% if block.settings.btn_label != blank %}
                  <a href="{{ block.settings.btn_link }}" class="hh-btn">{{ block.settings.btn_label }}</a>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>

      <!-- Slider Controls -->
      {% if slide_blocks.size > 1 %}
        <div class="hh-slider-controls">
          {% for block in slide_blocks %}
            <button class="hh-dot {% if forloop.first %}is-active{% endif %}" data-index="{{ forloop.index0 }}" aria-label="Go to slide {{ forloop.index }}"></button>
          {% endfor %}
        </div>
      {% endif %}
    </div>

    <!-- Feature Cards -->
    <div class="hh-features-wrapper">
      <div class="hh-features-grid">
        {% assign card_blocks = section.blocks | where: 'type', 'feature_card' %}
        {% for block in card_blocks %}
          <div class="hh-card {% if block.settings.highlight %}hh-card-highlight{% endif %}" {{ block.shopify_attributes }}>
            <div class="hh-card-icon">
              {% if block.settings.custom_icon != blank %}
                <img src="{{ block.settings.custom_icon | image_url: width: 100 }}" alt="{{ block.settings.title }}" loading="lazy" width="50" height="50">
              {% else %}
                {{ block.settings.icon_svg }}
              {% endif %}
            </div>
            <h3 class="hh-card-title">{{ block.settings.title }}</h3>
            <p class="hh-card-desc">{{ block.settings.description }}</p>
          </div>
        {% endfor %}
      </div>
    </div>

  </div>
</div>

<style>
  :root {
    --hh-brand-color: {{ section.settings.brand_color }};
    --hh-brand-color-hover: {{ section.settings.brand_color | color_darken: 10 }};
    --hh-dark-bg: {{ section.settings.dark_card_color }};
    --hh-light-bg: {{ section.settings.light_card_color }};
    --hh-text-dark: #333333;
    --hh-text-light: #ffffff;
    --hh-text-muted: #7A7A7A;
    --hh-transition: 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  /* Container & Layout */
  .hh-section {
    width: 100%;
    background-color: {{ section.settings.section_bg }};
    padding: 30px 20px 40px;
    box-sizing: border-box;
    overflow: hidden;
  }
  
  .hh-container {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    position: relative;
  }

  /* Floating Navbar */
  .hh-navbar {
    position: absolute;
    top: 20px;
    left: 0;
    right: 0;
    z-index: 100;
    margin: 0 auto;
    width: 95%;
    max-width: {{ section.settings.max_width | minus: 40 }}px;
    transition: all 0.3s ease;
  }

  .hh-navbar.is-sticky {
    position: fixed;
    top: 10px;
    width: calc(100% - 40px);
    box-shadow: 0 10px 40px rgba(0,0,0,0.08);
    animation: slideDown 0.5s ease;
    display: none;
  }

  @keyframes slideDown {
    from { transform: translateY(-100%); opacity: 0; }
    to { transform: translateY(0); opacity: 1; }
  }

  .hh-navbar-inner {
    background: rgba(255, 255, 255, 0.98);
    backdrop-filter: blur(10px);
    border-radius: 12px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 15px 30px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.04);
  }

  .hh-nav-left {
    display: flex;
    gap: 30px;
    flex: 1;
  }

  .hh-nav-link {
    text-decoration: none;
    color: var(--hh-brand-color);
    font-size: 14px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    transition: color 0.3s ease;
  }

  .hh-nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--hh-brand-color);
    transition: width var(--hh-transition);
  }

  .hh-nav-link:hover::after {
    width: 100%;
  }

  .hh-logo {
    flex: 1;
    display: flex;
    justify-content: center;
    text-decoration: none;
  }

  .hh-logo img {
    max-height: 80px;
    width: auto;
    object-fit: contain;
  }

  .hh-logo-text {
    font-size: 24px;
    color: var(--hh-brand-color);
    font-weight: bold;
  }

  .hh-nav-right {
    flex: 1;
    display: flex;
    justify-content: flex-end;
    gap: 15px;
    align-items: center;
  }

  .hh-icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--hh-brand-color);
    color: white;
    text-decoration: none;
    border-radius: 8px;
    height: 40px;
    padding: 0 15px;
    font-size: 14px;
    font-weight: 500;
    transition: all var(--hh-transition);
    gap: 8px;
  }

  .hh-icon-btn svg {
    width: 18px;
    height: 18px;
  }

  .hh-icon-btn:hover {
    background: var(--hh-brand-color-hover);
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(243, 102, 51, 0.3);
  }

  .hh-cart-btn {
    padding: 0 12px;
  }

  .hh-cart-count {
    background: white;
    color: var(--hh-brand-color);
    font-size: 11px;
    font-weight: bold;
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: absolute;
    top: -5px;
    right: -5px;
  }
  
  .hh-cart-btn { position: relative; }

  .hh-mobile-toggle, .hh-mobile-close {
    display: none;
    background: none;
    border: none;
    color: var(--hh-brand-color);
    cursor: pointer;
    padding: 5px;
  }
  
  .hh-mobile-toggle svg, .hh-mobile-close svg {
    width: 24px;
    height: 24px;
  }

  /* Hero Slider */
  .hh-hero-wrapper {
    position: relative;
    height: 880px;
    border-radius: 24px;
    overflow: hidden;
    background: #000;
  }

  .hh-slider {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .hh-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: 0;
    visibility: hidden;
    transition: opacity 1s ease-in-out, visibility 1s;
    z-index: 1;
  }

  .hh-slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 2;
  }

  .hh-slide-bg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    overflow: hidden;
  }

  .hh-slide-bg img, .hh-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.1);
    transition: transform 6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .hh-slide.is-active .hh-slide-bg img,
  .hh-slide.is-active .hh-placeholder {
    transform: scale(1);
  }

  .hh-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(to right, rgba(0,0,0,0.8) 0%, rgba(0,0,0,0.2) 60%, rgba(0,0,0,0) 100%);
  }

  .hh-slide-content-wrap {
    position: relative;
    z-index: 10;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    padding: 0 80px;
    box-sizing: border-box;
  }

  .hh-slide-content {
    max-width: 770px;
    margin-top: 60px; /* Offset for navbar */
  }

  .hh-slide-content > * {
    opacity: 0;
    transform: translateY(30px);
  }

  .hh-slide.is-active .hh-slide-content > * {
    animation: hh-fadeUp 0.8s forwards cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .hh-slide.is-active .hh-subtitle { animation-delay: 0.2s; }
  .hh-slide.is-active .hh-heading { animation-delay: 0.4s; }
  .hh-slide.is-active .hh-text { animation-delay: 0.6s; }
  .hh-slide.is-active .hh-btn { animation-delay: 0.8s; }

  @keyframes hh-fadeUp {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .hh-subtitle {
    color: var(--hh-brand-color);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 2px;
    font-weight: 600;
    margin-bottom: 15px;
  }

  .hh-heading {
    color: var(--hh-text-light);
    font-size: 74px;
    line-height: 1.1;
    margin: 0 0 20px 0;
    font-weight: 700;
  }

  .hh-text {
    color: rgba(255,255,255,0.9);
    font-size: 18px;
    line-height: 1.6;
    margin: 0 0 35px 0;
  }

  .hh-btn {
    display: inline-block;
    background: var(--hh-brand-color);
    color: white;
    text-decoration: none;
    padding: 16px 36px;
    font-size: 16px;
    font-weight: 600;
    border-radius: 8px;
    transition: all var(--hh-transition);
    position: relative;
    overflow: hidden;
  }

  .hh-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.2), transparent);
    transition: left 0.5s ease;
  }

  .hh-btn:hover {
    background: var(--hh-brand-color-hover);
    transform: translateY(-3px);
    box-shadow: 0 10px 20px rgba(243, 102, 51, 0.3);
  }

  .hh-btn:hover::before {
    left: 100%;
  }

  .hh-slider-controls {
    position: absolute;
    bottom: 160px;
    left: 80px;
    z-index: 10;
    display: none;
    gap: 10px;
  }

  .hh-dot {
    width: 30px;
    height: 3px;
    background: rgba(255,255,255,0.3);
    border: none;
    cursor: pointer;
    transition: all var(--hh-transition);
    padding: 0;
  }

  .hh-dot.is-active {
    background: var(--hh-brand-color);
    width: 40px;
  }

  /* Feature Cards */
  .hh-features-wrapper {
    position: relative;
    z-index: 20;
    margin-top: -100px;
    padding: 0 40px;
  }

  .hh-features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .hh-card {
    background: var(--hh-light-bg);
    border-radius: 12px;
    padding: 40px 30px;
    text-align: center;
    box-shadow: 0 15px 35px rgba(0,0,0,0.06);
    transition: all var(--hh-transition);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
  }

  .hh-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 25px 50px rgba(0,0,0,0.12);
  }

  .hh-card-icon {
    margin-bottom: 20px;
    color: var(--hh-brand-color);
    transition: transform var(--hh-transition);
  }

  .hh-card:hover .hh-card-icon {
    transform: scale(1.1);
  }

  .hh-card-icon svg {
    width: 48px;
    height: 48px;
    fill: currentColor;
  }

  .hh-card-title {
    font-size: 20px;
    color: var(--hh-text-dark);
    margin: 0 0 12px 0;
    font-weight: 600;
  }

  .hh-card-desc {
    font-size: 14px;
    color: var(--hh-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Highlighted Card */
  .hh-card.hh-card-highlight {
    background: var(--hh-dark-bg);
  }

  .hh-card-highlight .hh-card-icon {
    color: var(--hh-brand-color);
  }

  .hh-card-highlight .hh-card-title {
    color: var(--hh-text-light);
  }

  .hh-card-highlight .hh-card-desc {
    color: rgba(255,255,255,0.8);
  }

  /* Responsive Design */
  @media (max-width: 1200px) {
    .hh-heading { font-size: 50px; }
    .hh-slide-content-wrap { padding: 0 50px; }
    .hh-slider-controls { left: 50px; }
  }

  @media (max-width: 992px) {
    .hh-hero-wrapper { height: 750px; }
    .hh-features-grid { grid-template-columns: repeat(2, 1fr); gap: 15px; }
    .hh-features-wrapper { margin-top: -60px; padding: 0 20px; }
    .hh-slider-controls { bottom: 100px; }
    
    .hh-nav-left {
      position: fixed;
      top: 0;
      left: -110%;
      width: 300px;
      height: 100vh;
      background: white;
      flex-direction: column;
      padding: 80px 30px;
      box-shadow: 5px 0 30px rgba(0,0,0,0.1);
      transition: left 0.4s ease;
      z-index: 1000;
    }

    .hh-nav-left.is-open { left: 0; }
    
    .hh-mobile-toggle { display: block; flex: 1; text-align: left; }
    .hh-mobile-close { display: block; position: absolute; top: 20px; right: 20px; }
    .hh-logo { flex: 2; }
    .hh-nav-right { flex: 1; }
    .hh-login-btn span { display: none; }
  }

  @media (max-width: 768px) {
    .hh-section { padding: 20px 10px; }
    .hh-navbar { width: calc(100% - 20px); top: 10px; }
    .hh-navbar-inner { padding: 12px 15px; }
    
    .hh-hero-wrapper { height: 760px; border-radius: 16px; }
    .hh-slide-content-wrap { padding: 0 30px; text-align: center; }
    .hh-slide-content { margin: 0 auto; max-width: 100%; }
    .hh-overlay { background: linear-gradient(to top, rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.4) 50%, rgba(0,0,0,0.2) 100%); }
    
    .hh-heading { font-size: 34px; }
    .hh-text { font-size: 16px; margin-bottom: 25px; }
    .hh-slider-controls { left: 50%; transform: translateX(-50%); bottom: 180px; }
    
    .hh-features-wrapper { margin-top: -40px; padding: 0 10px; }
    .hh-features-grid { grid-template-columns: 1fr; gap: 12px; }
    .hh-card { padding: 30px 20px; }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const sectionId = '{{ section.id }}';
    const slider = document.getElementById(`Slider-${sectionId}`);
    
    if (slider) {
      const slides = slider.querySelectorAll('.hh-slide');
      const dots = document.querySelectorAll(`#HeelHeroes-${sectionId} .hh-dot`);
      const speed = parseInt(slider.dataset.speed) || 5000;
      let currentIndex = 0;
      let slideInterval;

      function goToSlide(index) {
        slides[currentIndex].classList.remove('is-active');
        if (dots.length) dots[currentIndex].classList.remove('is-active');
        
        currentIndex = index;
        
        slides[currentIndex].classList.add('is-active');
        if (dots.length) dots[currentIndex].classList.add('is-active');
      }

      function nextSlide() {
        let nextIndex = (currentIndex + 1) % slides.length;
        goToSlide(nextIndex);
      }

      function startSlider() {
        if (slides.length > 1) {
          slideInterval = setInterval(nextSlide, speed);
        }
      }

      function resetSlider() {
        clearInterval(slideInterval);
        startSlider();
      }

      dots.forEach((dot, index) => {
        dot.addEventListener('click', () => {
          goToSlide(index);
          resetSlider();
        });
      });

      startSlider();
    }

    // Sticky Navbar
    const navbar = document.getElementById(`Navbar-${sectionId}`);
    const heroWrapper = document.querySelector(`#HeelHeroes-${sectionId} .hh-hero-wrapper`);
    
    if (navbar && heroWrapper) {
      window.addEventListener('scroll', () => {
        if (window.scrollY > 150) {
          navbar.classList.add('is-sticky');
        } else {
          navbar.classList.remove('is-sticky');
        }
      });
    }

    // Mobile Menu
    const mobileToggle = document.getElementById(`MobileToggle-${sectionId}`);
    const mobileClose = document.getElementById(`MobileClose-${sectionId}`);
    const navMenu = document.getElementById(`NavMenu-${sectionId}`);

    if (mobileToggle && navMenu) {
      mobileToggle.addEventListener('click', () => {
        navMenu.classList.add('is-open');
      });
      mobileClose.addEventListener('click', () => {
        navMenu.classList.remove('is-open');
      });
    }
  });
</script>

{% schema %}
{
  "name": "Heel Heroes Section",
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 1000,
      "max": 2000,
      "step": 10,
      "unit": "px",
      "label": "Maximum Width",
      "default": 2000
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Outer Background",
      "default": "#f4ede6"
    },
    {
      "type": "header",
      "content": "Navbar"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo Image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "min": 50,
      "max": 300,
      "step": 10,
      "unit": "px",
      "label": "Logo Width",
      "default": 150
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation Menu"
    },
    {
      "type": "header",
      "content": "Theme Colors"
    },
    {
      "type": "color",
      "id": "brand_color",
      "label": "Brand Color (Buttons, Icons)",
      "default": "#F36633"
    },
    {
      "type": "color",
      "id": "dark_card_color",
      "label": "Highlighted Card Background",
      "default": "#54463F"
    },
    {
      "type": "color",
      "id": "light_card_color",
      "label": "Normal Card Background",
      "default": "#FAF8F5"
    },
    {
      "type": "header",
      "content": "Slider Settings"
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 3,
      "max": 10,
      "step": 1,
      "unit": "sec",
      "label": "Autoplay Speed",
      "default": 6
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Dark Overlay Opacity",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Hero Slide",
      "limit": 5,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Welcome to Heel Heroes"
        },
        {
          "type": "textarea",
          "id": "heading",
          "label": "Heading",
          "default": "Luxury Foot Care Your Heels Have Always Deserved"
